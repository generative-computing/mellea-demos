# LLM — OpenAI-compatible endpoint (default: Ollama)
LLM_URL=http://localhost:11434/v1
LLM_MODEL=granite4.1:3b
# LLM_API_KEY=ollama

# Whisper STT
WHISPER_MODEL=small

# Kokoro TTS
TTS_VOICE=bf_emma

# Set to true when LLM_MODEL is a Granite Switch model that exposes
# requirement_check ALoRA intrinsics. Gates the Best-of-N IVR validation path.
GRANITE_SWITCH_ENABLED=false

# Optional prompt file — prepended to the default system/instruct prompts
# PROMPT_FILE=prompt.txt

# Optional documents directory — all .txt files are loaded as mellea Documents
# and attached to user messages for RAG-style grounding
# DOCUMENTS_DIR=docs

# Server
HOST=localhost
PORT=7860
